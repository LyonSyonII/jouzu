// Folder-specific settings
//
// For a full list of overridable settings, and general information on folder-specific settings,
// see the documentation: https://zed.dev/docs/configuring-zed#settings-files
{
  "file_types": {
    "Angular": ["html"],
  },
  "languages": {
    "TypeScript": {
      "language_servers": ["!typescript-language-server", "!eslint", "angular", "vtsls", "..."],
    },
    "HTML": {
      "colorize_brackets": true,
      "semantic_tokens": "combined",
      "language_servers": ["angular", "..."],
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": ["prettier", "--stdin-filepath", "{buffer_path}", "--parser", "angular"],
        },
      },
    },
    "CSS": {
      "language_servers": ["tailwindcss-intellisense-css", "!vscode-css-language-server", "..."],
    },
  },
  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "experimental": {
          "classRegex": ["class=\"([^\"]*)\""],
        },
      },
    },
  },
}
