{
  "name": "jouzu",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "build": "ng build -c production",
    "watch": "ng build --watch --configuration development",
    "preview": "pnpm build && pnpx sirv-cli dist/jouzu/browser/ --single --etag --maxage 31536000 --immutable --port 4201 --gzip --brotli",
    "deploy": "ng deploy --cname=garriga.dev --base-href=/jouzu/",
    "serve:ssr:jouzu": "node dist/jouzu/server/server.mjs",
    "format": "prettier"
  },
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/service-worker": "^21.2.0",
    "@angular/ssr": "^21.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@primeuix/themes": "^2.0.3",
    "express": "^5.1.0",
    "fzstd": "^0.1.1",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.6",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-cli-ghpages": "^3.0.3",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
