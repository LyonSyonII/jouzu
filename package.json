{
  "name": "jouzu",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "build": "ng build -c production",
    "watch": "ng build --watch --configuration development",
    "preview": "pnpm build && pnpx sirv-cli dist/jouzu/browser/ --single --etag --maxage 31536000 --immutable --port 4201 --gzip --brotli",
    "release": "ng deploy --cname=garriga.dev --base-href=/jouzu/",
    "serve:ssr:jouzu": "node dist/jouzu/server/server.mjs",
    "format": "prettier"
  },
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@angular/common": "^21.2.13",
    "@angular/compiler": "^21.2.13",
    "@angular/core": "^21.2.13",
    "@angular/forms": "^21.2.13",
    "@angular/platform-browser": "^21.2.13",
    "@angular/platform-server": "^21.2.13",
    "@angular/router": "^21.2.13",
    "@angular/service-worker": "^21.2.13",
    "@angular/ssr": "^21.2.11",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@primeuix/themes": "^2.0.3",
    "angular-svg-icon": "^19.1.1",
    "core-js": "^3.49.0",
    "express": "^5.2.1",
    "fzstd": "^0.1.1",
    "idb-keyval": "^6.2.2",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.7",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.13",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.41",
    "angular-cli-ghpages": "^3.0.3",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "vitest": "^4.1.6"
  }
}
